> ### Name: mfv
> ### Title: Most frequent value (statistical mode) of frequency distribution
> ###   table (numerical and categorical variable)
> ### Aliases: mfv mfv.default mfv.fdt mfv.fdt.multiple mfv.fdt_cat
> ###   mfv.fdt_cat.multiple
> 
> ### ** Examples
> 
> library(fdth)
> 
> ## Numerical (multimodal examples)
> vx <- c(rep(3,
+             5),
+         rep(5,
+             5),
+         sample(6:10,
+                5))
> vx
 [1]  3  3  3  3  3  5  5  5  5  5  6  9  8 10  7
> mfv(vx)      # Two modes: 3 and 5
[1] 3 5
> 
> tb <- fdt(vx)
> tb
  Class limits f   rf rf(%) cf  cf(%)
  [2.97,4.396) 5 0.33 33.33  5  33.33
 [4.396,5.822) 5 0.33 33.33 10  66.67
 [5.822,7.248) 2 0.13 13.33 12  80.00
 [7.248,8.674) 1 0.07  6.67 13  86.67
  [8.674,10.1) 2 0.13 13.33 15 100.00
> mfv(tb)      # Mode estimated from grouped data (two modal classes)
[1] 4.396 4.396
> 
> vy <- c(rep(3,
+             5),
+         sample(6:9,
+                10,
+                rep=TRUE),
+         rep(10,
+             5))
> vy
 [1]  3  3  3  3  3  6  8  8  7  7  8  8  6  6  6 10 10 10 10 10
> 
> tb2 <- fdt(vy,
+            start=3,
+            end=11,
+            h=1)
