> base::assign(".dptime", (proc.time() - get(".ptime", pos = "CheckExEnv")), pos = "CheckExEnv")
> base::cat("summary", base::get(".format_ptime", pos = 'CheckExEnv')(get(".dptime", pos = "CheckExEnv")), "\n", file=base::get(".ExTimings", pos = 'CheckExEnv'), append=TRUE, sep="\t")
> cleanEx()
> nameEx("var")
> ### * var
> 
> flush(stderr()); flush(stdout())
> 
> base::assign(".ptime", proc.time(), pos = "CheckExEnv")
> ### Name: var
> ### Title: Variance of frequency distribution table (numerical variable)
> ### Aliases: var var.default var.fdt var.fdt.multiple
> 
> ### ** Examples
> 
> library(fdth)
> 
> mdf <- data.frame(x=rnorm(1e2,
+                           20,
+                           2),
+                   y=rnorm(1e2,
+                           30,
+                           3),
+                   z=rnorm(1e2,
+                           40,
+                           4))
> 
> head(mdf)
         x        y        z
1 18.74709 28.13890 41.63761
2 20.36729 30.12635 46.75549
3 18.32874 27.26724 46.34635
4 23.19056 30.47409 38.67637
5 20.65902 28.03625 30.85906
6 18.35906 35.30186 49.99065
> 
> # From a data.frame
> apply(mdf,
+       2,
+       var)
        x         y         z 
 3.227048  8.257791 17.115282 
> 
> # From a fdt object
> var(fdt(mdf))
$x
[1] 3.413503

$y
[1] 8.617097

$z
[1] 17.69853

> 
> unlist(var(fdt(mdf)))
        x         y         z 
 3.413503  8.617097 17.698535 
> 
> 
> 
> base::assign(".dptime", (proc.time() - get(".ptime", pos = "CheckExEnv")), pos = "CheckExEnv")
> base::cat("var", base::get(".format_ptime", pos = 'CheckExEnv')(get(".dptime", pos = "CheckExEnv")), "\n", file=base::get(".ExTimings", pos = 'CheckExEnv'), append=TRUE, sep="\t")
