> 
> flush(stderr()); flush(stdout())
> 
> base::assign(".ptime", proc.time(), pos = "CheckExEnv")
> ### Name: xtable.fdt
> ### Title: LaTeX table of the frequency distribution table
> ### Aliases: xtable.fdt xtable.fdt.multiple xtable.fdt_cat.multiple
> ### Keywords: xable fdt
