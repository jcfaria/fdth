        [5,6) 0 0.00     0  5    25
        [6,7) 4 0.20    20  9    45
        [7,8) 2 0.10    10 11    55
        [8,9) 4 0.20    20 15    75
       [9,10) 0 0.00     0 15    75
      [10,11) 5 0.25    25 20   100
> mfv(tb2)     # Two modes in non-adjacent classes
