> ### ** Examples
> 
> 
> library(fdth)
> library(xtable)
> 
> # +++++ Quantitative data
> ## Example 1: The simplest possible
> t1 <- fdt(rnorm(n=1e3,
+                 mean=10,
+                 sd=2))
> 
