> base::assign(".ptime", proc.time(), pos = "CheckExEnv")
> ### Name: plot.fdt
> ### Title: Plot fdt.default and fdt.multiple objects
> ### Aliases: plot.fdt plot.fdt.default plot.fdt.multiple
> ###   plot.fdt_cat.default plot.fdt_cat.multiple
> ### Keywords: fdt frequency distribution table plot histogram
> 
> ### ** Examples
> 
> library(fdth)
> 
> #===============================
> # Vectors: univariate numerical
> #===============================
> x <- rnorm(n=1e3,
+            mean=5,
+            sd=1)
> 
> (ft <- fdt(x))
 Class limits   f   rf rf(%)   cf cf(%)
   [1.97,2.6)  14 0.01   1.4   14   1.4
   [2.6,3.23)  34 0.03   3.4   48   4.8
  [3.23,3.86)  85 0.09   8.5  133  13.3
  [3.86,4.49) 168 0.17  16.8  301  30.1
  [4.49,5.12) 249 0.25  24.9  550  55.0
  [5.12,5.75) 225 0.22  22.5  775  77.5
  [5.75,6.38) 133 0.13  13.3  908  90.8
  [6.38,7.01)  67 0.07   6.7  975  97.5
